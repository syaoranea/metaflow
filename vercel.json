{
  "rewrites": [
    {
      "source": "/resolucao/_next/:match*",
      "destination": "https://metasflow-khrm.vercel.app/_next/:match*"
    },
    {
      "source": "/resolucao/:match*",
      "destination": "https://metasflow-khrm.vercel.app/:match*"
    },
    {
      "source": "/_next/:match*",
      "destination": "https://metaflow-ten.vercel.app/_next/:match*"
    },
    {
      "source": "/:match*",
      "destination": "https://metaflow-ten.vercel.app/:match*"
    }
  ]
}